# MongoDB (wajib) - dipakai juga untuk session store, jadi harus valid
MONGO_URI=mongodb+srv://user:pass@cluster.mongodb.net/dbname

# Vercel Blob (wajib untuk upload foto profil & gambar chat saat deploy di Vercel)
# Cara dapat: Project di Vercel > Storage > Create Database > Blob > connect ke project
# Vercel otomatis inject variabel ini ke environment saat Blob store sudah dihubungkan.
# Isi manual hanya untuk testing lokal.
BLOB_READ_WRITE_TOKEN=

# Secret untuk sign session cookie (opsional, kalau kosong pakai random tiap restart)
SESSION_SECRET=

PORT=3000
