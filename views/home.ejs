<%- include('partials/header', { title: 'Beranda' }) %>

<style>
  :root {
    --blue-500: #3b82f6;
    --blue-50: #eff6ff;
  }
  .text-blue-500 { color: var(--blue-500); }
  .bg-blue-50 { background-color: var(--blue-50); }
</style>

<div class="max-w-3xl <%= user ? 'pt-10' : 'pt-2' %> mx-auto px-6 pb-10">

  <!-- ========== HERO ========== -->
  <div class="bg-[#f9f9f9] border border-[#dddddd] rounded-[2px] px-6 py-16 mb-8 text-center">
    <% if (settings.logoUrl) { %>
      <img src="<%= settings.logoUrl %>" alt="Logo" class="w-16 h-16 mx-auto mb-4 object-contain rounded-[2px] border border-[#dddddd]" />
    <% } else { %>
      <div class="w-16 h-16 mx-auto mb-4 rounded-[2px] bg-blue-50 text-blue-500 flex items-center justify-center border border-[#dddddd]">
        <!-- Ikon dihapus -->
      </div>
    <% } %>

    <h1 class="text-lg md:text-2xl font-medium text-gray-800 mb-2">
      <%= settings.title || 'Platform Pembayaran QRIS Modern' %>
    </h1>
    <p class="text-xs font-medium text-gray-700 max-w-xl mx-auto leading-relaxed">
      <%= settings.description || 'Payment gateway otomatis untuk bisnis digital. Cepat, aman, dan biaya rendah.' %>
    </p>

    <div class="flex flex-col gap-3 mt-6 w-full">
      <a href="/register" class="w-full bg-blue-500 text-white py-3 px-3 rounded-[2px] text-xs font-medium shadow-sm hover:bg-blue-600 transition-colors flex items-center justify-center gap-2">
        Mulai Sekarang <i class="fas fa-arrow-right text-xs"></i>
      </a>
      <a href="/docs" class="w-full bg-white border border-[#dddddd] text-gray-700 py-3 px-3 rounded-[2px] text-xs font-medium shadow-sm hover:bg-gray-50 transition-colors flex items-center justify-center gap-2">
        <i class="fas fa-book text-xs"></i> Panduan API
      </a>
    </div>
  </div>

  <!-- ========== STATISTIK TERKINI ========== -->
  <% if (typeof stats !== 'undefined') { %>
  <div class="mb-8">
    <h2 class="text-sm font-medium text-gray-800 mb-4">Statistik <%= settings.name %> Terkini?</h2>
    <div class="grid grid-cols-1 sm:grid-cols-3 gap-4">
      <!-- Total Pengguna -->
      <div class="bg-[#f9f9f9] border border-[#dddddd] rounded-[2px] p-5 text-center">
        <p class="text-lg font-medium text-gray-800"><%= stats.totalUsers.toLocaleString('id-ID') %>+</p>
        <p class="text-xs font-medium text-gray-700 mt-1">Total Pengguna</p>
      </div>
      <!-- Total Pencairan 24 Jam (nominal withdraw) -->
      <div class="bg-[#f9f9f9] border border-[#dddddd] rounded-[2px] p-5 text-center">
        <p class="text-lg font-medium text-gray-800">Rp <%= stats.totalWithdrawAmount.toLocaleString('id-ID') %></p>
        <p class="text-xs font-medium text-gray-700 mt-1">Total Nominal Pencairan</p>
      </div>
      <!-- Total Nominal Transaksi (deposit + withdraw) -->
      <div class="bg-[#f9f9f9] border border-[#dddddd] rounded-[2px] p-5 text-center">
        <p class="text-lg font-medium text-gray-800">Rp <%= (stats.totalDepositAmount).toLocaleString('id-ID') %></p>
        <p class="text-xs font-medium text-gray-700 mt-1">Total Nominal Transaksi</p>
      </div>
    </div>
  </div>
  <% } %>

  <!-- ========== MENGAPA MEMILIH KAMI? ========== -->
  <div class="mb-8">
    <h2 class="text-sm font-medium text-gray-800 mb-4">Mengapa Pakai <%= settings.name %>?</h2>
    
    <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
      <div class="bg-[#f9f9f9] border border-[#dddddd] rounded-[2px] p-5">
        <div>
          <h3 class="text-sm font-medium text-gray-800 mb-1">Keamanan Berlapis</h3>
          <p class="text-xs font-medium text-gray-700 leading-relaxed">
            Autentikasi ketat, enkripsi data, dan pemantauan 24/7 menjaga setiap transaksi tetap aman.
          </p>
        </div>
      </div>

      <div class="bg-[#f9f9f9] border border-[#dddddd] rounded-[2px] p-5">
        <div>
          <h3 class="text-sm font-medium text-gray-800 mb-1">Proses Instan</h3>
          <p class="text-xs font-medium text-gray-700 leading-relaxed">
            Deposit masuk seketika, withdraw diproses cepat tanpa menunggu lama.
          </p>
        </div>
      </div>

      <div class="bg-[#f9f9f9] border border-[#dddddd] rounded-[2px] p-5">
        <div>
          <h3 class="text-sm font-medium text-gray-800 mb-1">API Simpel</h3>
          <p class="text-xs font-medium text-gray-700 leading-relaxed">
            Dokumentasi jelas, integrasi mudah — cukup beberapa baris kode untuk mulai menerima pembayaran.
          </p>
        </div>
      </div>

      <div class="bg-[#f9f9f9] border border-[#dddddd] rounded-[2px] p-5">
        <div>
          <h3 class="text-sm font-medium text-gray-800 mb-1">Biaya Rendah</h3>
          <p class="text-xs font-medium text-gray-700 leading-relaxed">
            Fee per transaksi sangat kompetitif sehingga margin bisnis Anda tetap maksimal.
          </p>
        </div>
      </div>
    </div>
  </div>

  <!-- ========== CARA KERJA ========== -->
  <div class="mb-8">
    <h2 class="text-sm font-medium text-gray-800 mb-4">Bagaimana Cara Memulai integrasi?</h2>
    
    <div class="grid grid-cols-1 sm:grid-cols-3 gap-4">
      <div class="bg-[#f9f9f9] border border-[#dddddd] rounded-[2px] p-5 text-lefr">
        <h3 class="text-sm font-medium text-gray-800 mb-1">1. Daftar Akun</h3>
        <p class="text-xs font-medium text-gray-700">Buat akun gratis & Ambil Apikey di menu Profil.</p>
      </div>
      
      <div class="bg-[#f9f9f9] border border-[#dddddd] rounded-[2px] p-5 text-left">
        <h3 class="text-sm font-medium text-gray-800 mb-1">2. Integrasi API</h3>
        <p class="text-xs font-medium text-gray-700">Gunakan endpoint simpel untuk generate QRIS dan cek status pembayaran.</p>
      </div>

      <div class="bg-[#f9f9f9] border border-[#dddddd] rounded-[2px] p-5 text-left">
        <h3 class="text-sm font-medium text-gray-800 mb-1">3. Terima Pembayaran</h3>
        <p class="text-xs font-medium text-gray-700">Dana langsung masuk ke saldo Anda.</p>
      </div>
    </div>
  </div>

  <!-- ========== CALL TO ACTION AKHIR ========== -->
  <div class="bg-[#f9f9f9] border border-[#dddddd] rounded-[2px] p-6 text-center">
    <h3 class="text-sm font-medium text-gray-800 mb-2">Siap Menerima Pembayaran QRIS?</h3>
    <p class="text-xs font-medium text-gray-700 mb-4">Gabung sekarang dan nikmati kemudahan transaksi otomatis.</p>
    <a href="/register" class="bg-blue-500 text-white px-6 py-2.5 rounded-[2px] text-xs font-medium shadow-sm hover:bg-blue-600 transition-colors inline-flex items-center gap-2">
      Buat Akun Gratis <i class="fas fa-arrow-right text-xs"></i>
    </a>
  </div>

</div>

<%- include('partials/footer') %>