<%- include('partials/header', { title: 'Buat Password Baru' }) %>

<div class="bg-[#f9f9f9] border border-[#dddddd] rounded-[2px] px-6 mx-6 mt-2 mb-10 py-6 min-h-[75vh] flex flex-col items-center justify-center">
  
  <!-- Logo / Ikon -->
  <div class="text-center mb-8">
    <% if (settings.logoUrl) { %>
      <img src="<%= settings.logoUrl %>" alt="Logo" class="w-14 h-14 rounded-[16px] object-cover mx-auto mb-4 shadow-sm border border-slate-100">
    <% } else { %>
      <div class="w-14 h-14 rounded-[16px] bg-pastel-blue text-finance-blue flex items-center justify-center text-xl mx-auto mb-4 shadow-sm">
        <i class="fa-solid fa-lock text-lg"></i>
      </div>
    <% } %>
    <h2 class="text-xl font-semibold text-slate-800 tracking-tight">Buat Password Baru</h2>
    <p class="text-xs font-medium text-slate-500 mt-1">Silakan masukkan password baru untuk akun Anda</p>
  </div>

  <!-- Alert Error -->
  <% if (typeof error !== 'undefined' && error) { %>
    <div class="w-full max-w-md bg-rose-50 border border-rose-100 text-rose-600 px-5 py-4 rounded-[20px] mb-6 text-xs font-semibold flex items-center gap-3">
      <div class="w-8 h-8 rounded-[12px] bg-rose-100 flex items-center justify-center shrink-0">
        <i class="fas fa-exclamation-circle text-xs"></i>
      </div>
      <p><%= error %></p>
    </div>
  <% } %>

  <!-- Form Reset Password -->
  <form method="POST" action="/reset-password/<%= typeof token !== 'undefined' ? token : '' %>" class="w-full max-w-md flex flex-col gap-4">
    
    <!-- Password Baru -->
    <div>
      <label class="block text-xs font-semibold text-slate-700 mb-2 px-1">Password Baru</label>
      <div class="flex items-center bg-slate-50 border border-slate-200 rounded-[16px] p-1.5 transition-all focus-within:border-finance-blue focus-within:ring-1 focus-within:ring-finance-blue">
        <div class="pl-3 text-slate-400 flex items-center">
          <i class="fas fa-lock text-xs"></i>
        </div>
        <input id="passwordInput1" name="password" type="password" placeholder="••••••••" 
               class="flex-1 bg-transparent px-2 py-2 text-xs font-semibold text-slate-800 outline-none w-full placeholder:text-xs placeholder:font-medium placeholder:text-slate-400" required>
        <button type="button" onclick="togglePassword('passwordInput1', 'toggleIcon1')" class="w-8 h-8 text-slate-400 hover:text-slate-600 transition-all flex items-center justify-center shrink-0 mr-1">
          <i id="toggleIcon1" class="far fa-eye text-xs"></i>
        </button>
      </div>
    </div>
    
    <!-- Konfirmasi Password -->
    <div>
      <label class="block text-xs font-semibold text-slate-700 mb-2 px-1">Konfirmasi Password</label>
      <div class="flex items-center bg-slate-50 border border-slate-200 rounded-[16px] p-1.5 transition-all focus-within:border-finance-blue focus-within:ring-1 focus-within:ring-finance-blue">
        <div class="pl-3 text-slate-400 flex items-center">
          <i class="fas fa-lock text-xs"></i>
        </div>
        <input id="passwordInput2" name="confirmPassword" type="password" placeholder="••••••••" 
               class="flex-1 bg-transparent px-2 py-2 text-xs font-semibold text-slate-800 outline-none w-full placeholder:text-xs placeholder:font-medium placeholder:text-slate-400" required>
        <button type="button" onclick="togglePassword('passwordInput2', 'toggleIcon2')" class="w-8 h-8 text-slate-400 hover:text-slate-600 transition-all flex items-center justify-center shrink-0 mr-1">
          <i id="toggleIcon2" class="far fa-eye text-xs"></i>
        </button>
      </div>
    </div>

    <button type="submit" class="bg-finance-blue hover:bg-finance-blue/90 text-white w-full py-4 rounded-[16px] text-xs font-semibold shadow-sm transition-all duration-200 hover:shadow-md hover:-translate-y-0.5 flex items-center justify-center gap-2 mt-2">
      Simpan Password Baru <i class="fas fa-arrow-right text-xs"></i>
    </button>
  </form>

</div>

<script>
  function togglePassword(inputId, iconId) {
    const passwordInput = document.getElementById(inputId);
    const toggleIcon = document.getElementById(iconId);
    
    if (passwordInput.type === 'password') {
      passwordInput.type = 'text';
      toggleIcon.classList.replace('fa-eye', 'fa-eye-slash');
    } else {
      passwordInput.type = 'password';
      toggleIcon.classList.replace('fa-eye-slash', 'fa-eye');
    }
  }
</script>

<%- include('partials/footer') %>