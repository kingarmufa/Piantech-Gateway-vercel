<%- include('partials/header', { title: 'Admin Dashboard' }) %>

<div class="app-container pb-6 mt-4 px-6 sm:px-6 pt-8 max-w-full overflow-x-hidden">

  <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4 mb-8">
    
    <div class="bg-white border border-[#dddddd] rounded-[2px]">
      <div class="bg-[#f9f9f9] border-b border-[#dddddd] px-4 py-3">
        <p class="text-sm font-medium text-gray-700 mb-0">Total Pengguna</p>
      </div>
      <div class="px-4 py-5">
        <p class="text-base font-medium text-gray-800 mb-0"><%= totalUsers %></p>
      </div>
    </div>

    <div class="bg-white border border-[#dddddd] rounded-[2px]">
      <div class="bg-[#f9f9f9] border-b border-[#dddddd] px-4 py-3">
        <p class="text-sm font-medium text-gray-700 mb-0">Total Uang Masuk</p>
      </div>
      <div class="px-4 py-5 flex items-center justify-start gap-2">
        <p class="text-base font-medium text-gray-800 mb-0">Rp <%= totalDepositAmount.toLocaleString('id-ID') %></p>
        <i class="far fa-eye text-xs text-gray-700 hover:text-gray-600 transition-colors cursor-pointer"></i>
      </div>
    </div>

    <div class="bg-white border border-[#dddddd] rounded-[2px]">
      <div class="bg-[#f9f9f9] border-b border-[#dddddd] px-4 py-3">
        <p class="text-sm font-medium text-gray-700 mb-0">Fee TRX Masuk</p>
      </div>
      <div class="px-4 py-5">
        <p class="text-base font-medium text-gray-800 mb-0">Rp <%= totalDepositFee.toLocaleString('id-ID') %></p>
      </div>
    </div>

    <div class="bg-white border border-[#dddddd] rounded-[2px]">
      <div class="bg-[#f9f9f9] border-b border-[#dddddd] px-4 py-3">
        <p class="text-sm font-medium text-gray-700 mb-0">Total Withdraw</p>
      </div>
      <div class="px-4 py-5">
        <p class="text-base font-medium text-gray-800 mb-0">Rp <%= totalWithdrawAmount.toLocaleString('id-ID') %></p>
      </div>
    </div>

    <div class="bg-white border border-[#dddddd] rounded-[2px]">
      <div class="bg-[#f9f9f9] border-b border-[#dddddd] px-4 py-3">
        <p class="text-sm font-medium text-gray-700 mb-0">Fee WD Masuk</p>
      </div>
      <div class="px-4 py-5">
        <p class="text-base font-medium text-gray-800 mb-0">Rp <%= totalWithdrawFee.toLocaleString('id-ID') %></p>
      </div>
    </div>

    <div class="bg-white border border-[#dddddd] rounded-[2px]">
      <div class="bg-[#f9f9f9] border-b border-[#dddddd] px-4 py-3">
        <p class="text-sm font-medium text-gray-700 mb-0">Total Transaksi</p>
      </div>
      <div class="px-4 py-5">
        <p class="text-base font-medium text-gray-800 mb-0"><%= totalTransactions %></p>
      </div>
    </div>

  </div>
</div>

<%- include('partials/footer') %>
