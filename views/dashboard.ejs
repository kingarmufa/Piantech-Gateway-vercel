<%- include('partials/header', { title: 'Dashboard' }) %>

<style>
  :root {
    --blue-500: #3b82f6;
    --blue-50: #eff6ff;
  }
  .text-blue-500 { color: var(--blue-500); }
  .bg-blue-50 { background-color: var(--blue-50); }
</style>

<div class="max-w-3xl mx-auto mt-4 px-6 pt-6 pb-10">

  <div class="bg-white border border-[#dddddd] rounded-[2px] mb-4">
    <div class="bg-[#f9f9f9] border-b border-[#dddddd] px-4 py-2">
      <span class="text-sm font-medium text-gray-700">Total Saldo Aktif</span>
    </div>
    
    <div class="px-4 py-5">
      <div class="flex items-center justify-start gap-2">
        <h2 id="balanceReal" class="text-base font-medium text-gray-800 flex items-baseline gap-1 mb-0">
          <span class="text-base font-medium">Rp</span> <%= user.balance.toLocaleString('id-ID') %>
        </h2>
        <h2 id="balanceHidden" class="text-base font-medium text-gray-800 hidden mb-0">
          Rp •••••••
        </h2>
        <button onclick="toggleBalance()" class="text-gray-700 hover:text-gray-600 transition-colors">
          <i id="balanceEyeIcon" class="far fa-eye text-xs"></i>
        </button>
      </div>
    </div>
  </div>

  <div class="grid grid-cols-1 sm:grid-cols-3 gap-4 mb-4">
    <div class="bg-white border border-[#dddddd] rounded-[2px]">
      <div class="bg-[#f9f9f9] border-b border-[#dddddd] px-4 py-2">
        <p class="text-sm font-medium text-gray-700 mb-0">Total Pemasukan</p>
      </div>
      <div class="px-4 py-5">
        <p class="text-base font-medium text-gray-800 mb-0">Rp <%= totalDeposit.toLocaleString('id-ID') %></p>
      </div>
    </div>

    <div class="bg-white border border-[#dddddd] rounded-[2px]">
      <div class="bg-[#f9f9f9] border-b border-[#dddddd] px-4 py-2">
        <p class="text-sm font-medium text-gray-700 mb-0">Total Pengeluaran</p>
      </div>
      <div class="px-4 py-5">
        <p class="text-base font-medium text-gray-800 mb-0">Rp <%= totalWithdraw.toLocaleString('id-ID') %></p>
      </div>
    </div>

    <div class="bg-white border border-[#dddddd] rounded-[2px]">
      <div class="bg-[#f9f9f9] border-b border-[#dddddd] px-4 py-2">
        <p class="text-sm font-medium text-gray-700 mb-0">Total Transaksi</p>
      </div>
      <div class="px-4 py-5">
        <p class="text-base font-medium text-gray-800"><%= recentTrx.length %> Transaksi</p>
        <a href="/deposit" class="inline-flex items-center gap-1 text-xs font-medium text-blue-500 hover:no-underline transition-colors">
          Lihat Semua Transaksi <i class="fas fa-arrow-right text-xs"></i>
        </a>
      </div>
    </div>
  </div>

</div>

<script>
  function toggleBalance() {
    const real = document.getElementById('balanceReal');
    const hidden = document.getElementById('balanceHidden');
    const icon = document.getElementById('balanceEyeIcon');

    real.classList.toggle('hidden');
    hidden.classList.toggle('hidden');

    if (icon) {
      icon.classList.toggle('fa-eye');
      icon.classList.toggle('fa-eye-slash');
    }
  }
</script>

<%- include('partials/footer') %>
