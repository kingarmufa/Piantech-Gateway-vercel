<%- include('partials/header', { title: 'Daftar Akun' }) %>

<style>
  :root {
    --blue-500: #3b82f6;
    --blue-50: #eff6ff;
  }
  .text-blue-500 { color: var(--blue-500); }
  .bg-blue-50 { background-color: var(--blue-50); }
</style>

<div class="bg-[#f9f9f9] border border-[#dddddd] rounded-[2px] px-6 mx-6 mt-2 mb-10 py-6 min-h-[75vh] flex flex-col items-center justify-center">
  
  <!-- Logo / Ikon -->
  <div class="text-center mb-8">
    <% if (settings.logoUrl) { %>
      <img src="<%= settings.logoUrl %>" alt="Logo" class="w-14 h-14 rounded-[2px] object-cover mx-auto mb-4 border border-[#dddddd]">
    <% } else { %>
      <div class="w-14 h-14 rounded-[2px] bg-blue-50 text-blue-500 flex items-center justify-center text-xl mx-auto mb-4 border border-[#dddddd]">
        <!-- Ikon dihapus -->
      </div>
    <% } %>
    <h2 class="text-lg font-medium text-gray-800">Buat Akun Baru</h2>
  </div>

  <!-- Alert Error -->
  <% if (typeof error !== 'undefined' && error) { %>
    <div class="w-full max-w-md bg-[#fef2f2] border border-[#fecaca] text-[#dc2626] px-5 py-4 rounded-[2px] mb-6 text-xs font-medium flex items-center gap-3">
      <p><%= error %></p>
    </div>
  <% } %>

  <!-- Form Register -->
  <form method="POST" action="/register" class="w-full max-w-md flex flex-col gap-1" autocomplete="off">
    
    <!-- Username -->
    <div>
      <label class="block text-xs font-medium text-gray-800 mb-2 px-1">Username</label>
      <input id="usernameInput" name="username" type="text" placeholder="username" 
             class="w-full bg-[#f9f9f9] border border-[#dddddd] rounded-[2px] px-4 py-3 text-xs font-medium text-gray-800 outline-none transition-all focus:border-blue-500 focus:ring-1 focus:ring-blue-500 placeholder:text-xs placeholder:font-medium placeholder:text-gray-400" 
             maxlength="15" minlength="4" pattern="[a-z0-9]+" title="Username 4-15 karakter, hanya huruf kecil dan angka" required>
      <div id="usernameStatus" class="mt-1 text-[10px] font-medium min-h-[16px] px-1"></div>
    </div>

    <!-- Email -->
    <div>
      <label class="block text-xs font-medium text-gray-800 mb-2 px-1">Alamat Email</label>
      <input id="emailInput" name="email" type="email" placeholder="nama@email.com" 
             class="w-full bg-[#f9f9f9] border border-[#dddddd] rounded-[2px] px-4 py-3 text-xs font-medium text-gray-800 outline-none transition-all focus:border-blue-500 focus:ring-1 focus:ring-blue-500 placeholder:text-xs placeholder:font-medium placeholder:text-gray-400" required>
      <div id="emailStatus" class="mt-1 text-[10px] font-medium min-h-[16px] px-1"></div>
    </div>
    
    <!-- Password -->
    <div>
      <label class="block text-xs font-medium text-gray-800 mb-2 px-1">Password</label>
      <div class="flex items-center bg-[#f9f9f9] border border-[#dddddd] rounded-[2px] transition-all focus-within:border-blue-500 focus-within:ring-1 focus-within:ring-blue-500">
        <input id="passwordInput" name="password" type="password" placeholder="••••••••" 
               class="flex-1 bg-transparent px-4 py-3 text-xs font-medium text-gray-800 outline-none w-full placeholder:text-xs placeholder:font-medium placeholder:text-gray-400" required>
        <button type="button" onclick="togglePassword()" class="w-9 h-9 text-gray-400 hover:text-gray-600 transition-all flex items-center justify-center shrink-0 mr-1">
          <i id="toggleIcon" class="far fa-eye text-xs"></i>
        </button>
      </div>
    </div>

    <!-- Tombol Daftar -->
    <button type="submit" id="submitBtn" class="bg-blue-500 hover:bg-blue-600 text-white w-full py-3 rounded-[2px] text-xs font-medium shadow-sm transition-all flex items-center justify-center gap-2 mt-2 disabled:opacity-60 disabled:cursor-not-allowed">
      Daftar Sekarang
    </button>
  </form>

  <!-- Link Login -->
  <p class="mt-6 text-center text-xs font-medium text-gray-700 max-w-md w-full">
    Sudah punya akun? 
    <a href="/login" class="text-blue-500 font-medium hover:underline transition-colors">Masuk di sini</a>
  </p>
</div>

<script>
  // --- Toggle Password ---
  function togglePassword() {
    const passwordInput = document.getElementById('passwordInput');
    const toggleIcon = document.getElementById('toggleIcon');
    if (passwordInput.type === 'password') {
      passwordInput.type = 'text';
      toggleIcon.classList.replace('fa-eye', 'fa-eye-slash');
    } else {
      passwordInput.type = 'password';
      toggleIcon.classList.replace('fa-eye-slash', 'fa-eye');
    }
  }

  // --- Cek Ketersediaan Username / Email (POST) ---
  const usernameInput = document.getElementById('usernameInput');
  const emailInput = document.getElementById('emailInput');
  const usernameStatus = document.getElementById('usernameStatus');
  const emailStatus = document.getElementById('emailStatus');
  const submitBtn = document.getElementById('submitBtn');

  let usernameCheckTimer;
  let emailCheckTimer;

  async function checkAvailability(type, value, statusEl) {
    if (!value) {
      statusEl.innerHTML = '';
      updateSubmitButton();
      return;
    }

    if (type === 'username' && value.length < 4) {
      statusEl.innerHTML = '<span class="text-gray-400">Minimal 4 karakter</span>';
      updateSubmitButton();
      return;
    }

    try {
      const res = await fetch('/check-availability', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ type, value })
      });
      const data = await res.json();
      if (data.available) {
        statusEl.innerHTML = `<span class="text-emerald-600">✓ ${data.message}</span>`;
      } else {
        statusEl.innerHTML = `<span class="text-rose-600">✗ ${data.message}</span>`;
      }
    } catch (err) {
      statusEl.innerHTML = `<span class="text-gray-400">⚠ Tidak dapat memeriksa</span>`;
    }
    updateSubmitButton();
  }

  function updateSubmitButton() {
    const usernameText = usernameStatus.textContent;
    const emailText = emailStatus.textContent;
    const usernameInvalid = usernameText.includes('tidak valid') ||
                            usernameText.includes('sudah digunakan') ||
                            usernameText.includes('Tidak dapat') ||
                            usernameText.includes('Minimal 4 karakter');
    const emailInvalid = emailText.includes('tidak valid') ||
                         emailText.includes('sudah terdaftar') ||
                         emailText.includes('Tidak dapat');
    submitBtn.disabled = (usernameInvalid || emailInvalid);
  }

  // --- Event listener untuk username: auto lowercase + pengecekan ---
  usernameInput.addEventListener('input', function() {
    this.value = this.value.toLowerCase();
    clearTimeout(usernameCheckTimer);
    const val = this.value.trim();
    usernameCheckTimer = setTimeout(() => checkAvailability('username', val, usernameStatus), 400);
  });

  emailInput.addEventListener('input', function() {
    clearTimeout(emailCheckTimer);
    const val = this.value.trim();
    if (val && /^\S+@\S+\.\S+$/.test(val)) {
      emailCheckTimer = setTimeout(() => checkAvailability('email', val, emailStatus), 400);
    } else {
      emailStatus.innerHTML = val ? '<span class="text-gray-400">Format email tidak valid</span>' : '';
      updateSubmitButton();
    }
  });
</script>

<%- include('partials/footer') %>