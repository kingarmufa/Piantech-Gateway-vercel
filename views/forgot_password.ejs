<%- include('partials/header', { title: 'Lupa Password' }) %>

<style>
  :root {
    --blue-500: #3b82f6;
    --blue-50: #eff6ff;
  }
  .text-blue-500 { color: var(--blue-500); }
  .bg-blue-50 { background-color: var(--blue-50); }
</style>

<div class="bg-[#f9f9f9] border border-[#dddddd] rounded-[2px] px-6 mx-6 mt-2 mb-10 py-6 min-h-[75vh] flex flex-col items-center justify-center">
  
  <!-- Logo / Ikon -->
  <div class="text-center mb-8">
    <% if (settings.logoUrl) { %>
      <img src="<%= settings.logoUrl %>" alt="Logo" class="w-14 h-14 rounded-[2px] object-cover mx-auto mb-4 border border-[#dddddd]">
    <% } else { %>
      <div class="w-14 h-14 rounded-[2px] bg-blue-50 text-blue-500 flex items-center justify-center text-xl mx-auto mb-4 border border-[#dddddd]">
        <!-- Ikon dihapus -->
      </div>
    <% } %>
    <h2 class="text-lg font-medium text-gray-800">Lupa Password</h2>
  </div>

  <!-- Alert Error -->
  <% if (typeof error !== 'undefined' && error) { %>
    <div class="w-full max-w-md bg-[#fef2f2] border border-[#fecaca] text-[#dc2626] px-5 py-4 rounded-[2px] mb-6 text-xs font-medium flex items-center gap-3">
      <p><%= error %></p>
    </div>
  <% } %>

  <!-- Alert Success -->
  <% if (typeof success !== 'undefined' && success) { %>
    <div class="w-full max-w-md bg-[#f0fdf4] border border-[#bbf7d0] text-[#16a34a] px-5 py-4 rounded-[2px] mb-6 text-xs font-medium flex items-center gap-3">
      <p><%= success %></p>
    </div>
  <% } %>

  <!-- Form Lupa Password -->
  <form method="POST" action="/forgot-password" class="w-full max-w-md flex flex-col gap-4">
    <div>
      <label class="block text-xs font-medium text-gray-800 mb-2 px-1">Email atau Username</label>
      <input name="login" type="text" placeholder="username atau email" 
             class="w-full bg-[#f9f9f9] border border-[#dddddd] rounded-[2px] px-4 py-3 text-xs font-medium text-gray-800 outline-none transition-all focus:border-blue-500 focus:ring-1 focus:ring-blue-500 placeholder:text-xs placeholder:font-medium placeholder:text-gray-400" 
             required
             oninput="this.value = this.value.toLowerCase()">
    </div>

    <button type="submit" class="bg-blue-500 hover:bg-blue-600 text-white w-full py-3 rounded-[2px] text-xs font-medium shadow-sm transition-all flex items-center justify-center gap-2 mt-2">
      Kirim Link Reset
    </button>
  </form>

  <!-- Link Kembali ke Login -->
  <p class="mt-6 text-center text-xs font-medium text-gray-700 max-w-md w-full">
    Ingat password Anda? 
    <a href="/login" class="text-blue-500 font-medium hover:underline transition-colors">Masuk di sini</a>
  </p>
</div>

<%- include('partials/footer') %>